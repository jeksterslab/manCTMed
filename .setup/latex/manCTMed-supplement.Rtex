\begin{table*}
	\begin{threeparttable}
		\footnotesize
		\caption{Point Estimates, SEs, and 95\% CIs of the Direct, Indirect, and Total Effects for Data Simulated from \textcite{Grundy-Gondoli-BlodgettSalafia-2007}}
		\label{tab:manCTMed-example-2}
		\begin{tabular}{@{}clccccccccc@{}}
			\toprule
			$\Delta t$            & Effect & Estimate & SE & 2.5\% & 97.5\% & $\mathrm{Sym}^{\ast}$ & SE & 2.5\% & 97.5\% & $\mathrm{Sym}^{\ast}$ \\ \midrule
			& & & \multicolumn{4}{c}{Delta} & \multicolumn{4}{c}{MC} \\
			\cmidrule(lr){4-7}
			\cmidrule(lr){8-11}
			& & & \multicolumn{8}{c}{$n = 100$} \\
			\cmidrule(lr){4-11}
			\rinline{table_ci_100} \midrule
			& & & \multicolumn{8}{c}{$n = 200$} \\
			\cmidrule(lr){4-11}
			\rinline{table_ci_200} \midrule
			& & & \multicolumn{8}{c}{$n = 500$} \\
			\cmidrule(lr){4-11}
			\rinline{table_ci_500} \midrule
			& & & \multicolumn{8}{c}{$n = 1,000$} \\
			\cmidrule(lr){4-11}
			\rinline{table_ci_1000} \midrule
			\bottomrule
		\end{tabular}
		\begin{tablenotes}[para,flushleft]
			{\scriptsize
				\textit{Note.} Delta and MC SEs and CIs are calculated using the \texttt{DeltaMed} and \texttt{MCMed} functions from the \texttt{cTMed} package, respectively.
								    
				$^{\ast}$The symmetry of the CIs is assessed using the absolute value of $2.5\% - \mathrm{estimate} + 97.5\% - \mathrm{estimate}$. Values greater than zero indicate asymmetry.
			}
		\end{tablenotes}
	\end{threeparttable}
\end{table*}

