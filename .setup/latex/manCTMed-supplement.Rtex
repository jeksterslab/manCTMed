\begin{sidewaystable*}
	\begin{threeparttable}
		\caption{Point Estimates and 95\% CIs of the CT-VAR Drift Matrix $\boldsymbol{\Phi}$ and the DT-VAR ($\Delta t = 1$) Lagged Coefficients Matrix $\boldsymbol{\beta}$ for Data Simulated from \textcite{Grundy-Gondoli-BlodgettSalafia-2007}}
		\label{tab:manCTMed-example-1}
		\begin{tabular}{@{}lcccccccc@{}}
			\toprule
			Parameter & Estimate & 2.5\% & 97.5\% & Estimate & 2.5\% & 97.5\% & 2.5\% & 97.5\% \\ \midrule
			& \multicolumn{3}{c}{$CT-VAR$} & \multicolumn{5}{c}{DT-VAR} \\
			\cmidrule(lr){2-4}
			\cmidrule(lr){5-9}
			&  &  &  &  & \multicolumn{2}{c}{Delta} & \multicolumn{2}{c}{MC} \\
			\cmidrule(lr){6-7}
			\cmidrule(lr){8-9}
			\rinline{table_coef}
			\bottomrule
		\end{tabular}
		\begin{tablenotes}[para,flushleft]
			{\small
				\textit{Note.}
				Estimates for the CT-VAR are calculated using the \texttt{dynr} package.
				Estimates for the DT-VAR are calculated
				using the \texttt{DeltaBeta} (delta method) and \texttt{MCBeta} (MC) functions from the \texttt{cTMed} package. These results are based on simulated data with $n = 1,000$.
			}
		\end{tablenotes}
	\end{threeparttable}
\end{sidewaystable*}

