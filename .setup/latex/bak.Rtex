        \caption{Weak Coupling ($\boldsymbol{\Phi}_{3}$)}
		\centering
	    \includegraphics[scale = .76, trim = 0 0 0 50, clip]{.setup/latex/figures/png/fig-vignettes-scatter-plots-effects-neg-1.png}
