\subsection{Parameters}

\Textcite{Deboeck-Preacher-2015} generated data from a DT-VAR model using a fixed time interval of one unit with the following parameters
\begin{equation*}
	\boldsymbol{\alpha}_{\Delta t \left( 1 \right)}
	=
	\left(
	\begin{array}{c}
		\rinline{eq_alpha_1} 
	\end{array}
	\right) ,
    \quad
	\boldsymbol{\beta}_{\Delta t \left( 1 \right)}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_beta_1} 
	\end{array}
	\right) ,
    \quad
    \text{and}
    \quad
	\boldsymbol{\Psi}_{\Delta t \left( 1 \right)}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_psi_1} 
	\end{array}
	\right)
\end{equation*}
and initial values of $\eta_{X}$, $\eta_{M}$, and $\eta_{Y}$ sampled from a standard multivariate normal distribution. Using the DT-VAR parameters above, we derived the CT-VAR parameters following the approach proposed by \Textcite{Chow-Losardo-Park-etal-2023}, arriving at the following
\begin{equation*}
	\boldsymbol{\mu}
	=
	\left(
	\begin{array}{c}
		\rinline{eq_mu} 
	\end{array}
	\right) ,
    \quad
	\boldsymbol{\Phi}_{\textcolor{blue}{1}}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_phi} 
	\end{array}
	\right) ,
    \quad
    \text{and}
    \quad
	\boldsymbol{\Sigma}_{\textcolor{blue}{1}}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_sigma} 
	\end{array}
	\right) .
\end{equation*}
We used the same mean vector and covariance matrix to generate the initial values of $\eta_{X}$, $\eta_{M}$, and $\eta_{Y}$. In addition to \Textcite{Deboeck-Preacher-2015}, we included a measurement model for the observed variables with the following parameters
\begin{equation*}
	\boldsymbol{\nu}
	=
	\left(
	\begin{array}{c}
		\rinline{eq_nu} 
	\end{array}
	\right) ,
    \quad
	\boldsymbol{\Lambda}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_lambda} 
	\end{array}
	\right) ,
    \quad
    \text{and}
    \quad
	\boldsymbol{\Theta}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_theta} 
	\end{array}
	\right) .
\end{equation*}

\textcolor{blue}{To capture diverse dynamics, we included two additional sets of drift matrices and process noise covariance matrices:}
\begin{equation*}
    \textcolor{blue}{
	\boldsymbol{\Phi}_{2}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_phi_pos} 
	\end{array}
	\right) ,
    \quad
	\boldsymbol{\Sigma}_{2}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_sigma_pos} 
	\end{array}
	\right) \quad \mathrm{and}
    }
\end{equation*}

\begin{equation*}
    \textcolor{blue}{
	\boldsymbol{\Phi}_{3}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_phi_neg} 
	\end{array}
	\right) ,
    \quad
	\boldsymbol{\Sigma}_{3}
	=
	\left(
	\begin{array}{ccc}
		\rinline{eq_sigma_neg} 
	\end{array}
	\right) .
    }
\end{equation*}
\textcolor{blue}{These matrices represent three dynamic regimes: (1) moderate coupling (intermediate decay, meaningful interactions), (2) strong coupling (rapid decay, intensified interactions), and (3) weak coupling (slow decay, minimal interactions). This variability enables a comprehensive examination of system dynamics, from tightly coupled fast-evolving processes to near-independent slow evolution, ensuring robust and generalizable insights into system behavior. The process noise covariance matrices were chosen such that the model-implied state covariance matrix for the three cases are essentially the same.} The direct, indirect, and total effects that correspond to the drift matri\textcolor{blue}{ces $\boldsymbol{\Phi}_{1}$, $\boldsymbol{\Phi}_{2}$, and $\boldsymbol{\Phi}_{3}$} are plotted in Figure \ref{fig:simulation-effects}.

\begin{figure*}
	\caption{Total, Direct, and Indirect Effects Used in the Monte Carlo Simulation Study}
	\begin{subfigure}{\textwidth}
        \caption{Moderate Coupling ($\boldsymbol{\Phi}_{1}$)}
		\centering
	    \includegraphics[scale = .76, trim = 0 0 0 50, clip]{.setup/latex/figures/png/fig-vignettes-scatter-plots-effects-zero-1.png}
		\label{fig:manCTMed-effects-1}
	\end{subfigure}
    \medskip
	\begin{subfigure}{\textwidth}
        \caption{Strong Coupling ($\boldsymbol{\Phi}_{2}$)}
		\centering
	    \includegraphics[scale = .76, trim = 0 0 0 50, clip]{.setup/latex/figures/png/fig-vignettes-scatter-plots-effects-pos-1.png}
		\label{fig:manCTMed-effects-2}
	\end{subfigure}
    \medskip
