```{r}
#| include = FALSE
data_process_example_med_sim_plot <- function(n,
                                              model,
                                              effect,
                                              delta_t_max = 10) {
  method <- "delta"
  # find root directory
  root <- rprojroot::is_rstudio_project
  
  # all -----------------------------------------
  ci_file_100 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      100,
      ".Rds"
    )
  )
  ci_100 <- readRDS(
    ci_file_100
  )
  ci_100 <- ci_100[which(ci_100$interval <= delta_t_max), ]
  ci_100 <- ci_100[which(ci_100$model == model), ]
  
  ci_file_200 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      200,
      ".Rds"
    )
  )
  ci_200 <- readRDS(
    ci_file_200
  )
  ci_200 <- ci_200[which(ci_200$interval <= delta_t_max), ]
  ci_200 <- ci_200[which(ci_200$model == model), ]
  
  ci_file_500 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      500,
      ".Rds"
    )
  )
  ci_500 <- readRDS(
    ci_file_500
  )
  ci_500 <- ci_500[which(ci_500$interval <= delta_t_max), ]
  ci_500 <- ci_500[which(ci_500$model == model), ]
  
  ci_file_1000 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      1000,
      ".Rds"
    )
  )
  ci_1000 <- readRDS(
    ci_file_1000
  )
  ci_1000 <- ci_1000[which(ci_1000$interval <= delta_t_max), ]
  ci_1000 <- ci_1000[which(ci_1000$model == model), ]
  ci_combined <- rbind(
    ci_100,
    ci_200,
    ci_500,
    ci_1000
  )
  # all -----------------------------------------
  
  method_label <- "Simulation CIs"
  graphics::plot.default(
    x = 0,
    y = 0,
    xlim = range(ci_combined$interval),
    ylim = range(c(ci_combined$est, ci_combined$ll, ci_combined$ul)),
    type = "n",
    xlab = "Time Interval",
    ylab = "Estimate",
    main =  paste0(
      gsub(
        pattern = "(^|[[:space:]])([[:alpha:]])",
        replacement = "\\1\\U\\2",
        x = effect,
        perl = TRUE
      ),
      " Effect",
      " | ",
      method_label,
      " | ",
      "n = ",
      n
    )
  )
  if (effect == "total") {
    col <- "#5e3c99"
  }
  if (effect == "direct") {
    col <- "#2c7bb6"
  }
  if (effect == "indirect") {
    col <- "#d7191c"
  }
  fit_example_ct_sim <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "fit-example-ct-sim-",
      n,
      ".Rds"
    )
  )
  sim <- readRDS(fit_example_ct_sim)
  sim <- sim[which(sim$interval <= delta_t_max), ]
  sim <- sim[which(sim$model == model), ]
  sim <- sim[which(sim$n == n), ]
  sim <- sim[, c("interval", effect)]
  delta_t <- unique(sim$interval)
  ci <- do.call(
    what = "rbind",
    args = lapply(
      X = delta_t,
      FUN = function(i) {
        return(
          c(
            interval = i,
            quantile(
              x = sim[which(sim$interval == i), effect],
              probs = c(0.025, 0.975)
            )
          )
        )
      }
    )
  )
  ci <- as.data.frame(ci)
  colnames(ci) <- c("interval", "ll", "ul")
  # estimates
  library(cTMed)
  fit <- readRDS(
    root$find_file(
      ".setup",
      "data-raw",
      paste0(
        "fit-example-ct-",
        n,
        ".Rds"
      )
    )
  )
  varnames <- c(
    "phi_11",
    "phi_21",
    "phi_31",
    "phi_12",
    "phi_22",
    "phi_32",
    "phi_13",
    "phi_23",
    "phi_33"
  )
  phi <- matrix(
    data = coef(fit)[varnames],
    nrow = 3
  )
  colnames(phi) <- rownames(phi) <- c(
    "conflict",
    "knowledge",
    "competence"
  )
  est <- summary(
    Med(
      phi = phi,
      from = "conflict",
      to = "competence",
      med = "knowledge",
      delta_t = delta_t
    )
  )[, effect]
  for (i in seq_along(ci$interval)) {
    if (!(ci$ll[i] <= 0 && 0 <= ci$ul[i])) {
      graphics::segments(
        x0 = ci$interval[i],
        y0 = ci$ll[i],
        x1 = ci$interval[i],
        y1 = ci$ul[i],
        col = col,
        lty = 3,
        lwd = 1
      )
    }
  }
  for (i in seq_along(ci$interval)) {
    if (!(ci$ll[i] <= 0 && 0 <= ci$ul[i])) {
      graphics::segments(
        x0 = ci$interval[i],
        y0 = ci$ll[i],
        x1 = ci$interval[i],
        y1 = ci$ul[i],
        col = col,
        lty = 3,
        lwd = 1
      )
    }
  }
  graphics::abline(
    h = 0
  )
  graphics::lines(
    x = ci$interval,
    y = est,
    type = "l",
    col = col,
    lty = 1,
    lwd = 3
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ll,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ul,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
}
```

