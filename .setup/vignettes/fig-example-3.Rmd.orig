```{r}
#| include = FALSE
root <- rprojroot::is_rstudio_project
n <- 500
fit <- readRDS(
  root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "fit-example-ct-",
      n,
      ".Rds"
    )
  )
)
```

```{r}
library(dynr)
library(cTMed)
```

## Summary of CT-VAR Estimates

```{r}
summary(fit)
```

## Extract Elements of the Drift Matrix

```{r}
varnames <- c(
  "phi_11",
  "phi_21",
  "phi_31",
  "phi_12",
  "phi_22",
  "phi_32",
  "phi_13",
  "phi_23",
  "phi_33"
)
phi <- matrix(
  data = coef(fit)[varnames],
  nrow = 3
)
colnames(phi) <- rownames(phi) <- c(
  "conflict",
  "knowledge",
  "competence"
)
vcov_phi_vec <- vcov(fit)[varnames, varnames]
```

## Delta Method Confidence Intervals For The Direct, Indirect, and Total Effects

A long sequence of time-interval values makes regions of significance more visible.

```{r}
delta <- DeltaMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = seq(from = 0, to = 10, length.out = 1000)
)
plot(delta)
```

## Monte Carlo Method Confidence Intervals For The Direct, Indirect, and Total Effects

```{r}
mc <- MCMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = seq(from = 0, to = 10, length.out = 1000),
  seed = 42,
  R = 20000L
)
plot(mc)
```

```{r}
#| include = FALSE
data_process_example_med_plot <- function(n,
                                          model,
                                          effect,
                                          method,
                                          delta_t_max = 10) {
  # find root directory
  root <- rprojroot::is_rstudio_project
  ci_file <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      n,
      ".Rds"
    )
  )
  ci <- readRDS(
    ci_file
  )
  ci <- ci[which(ci$interval <= delta_t_max), ]
  ci <- ci[which(ci$model == model), ]
  ci <- ci[which(ci$n == n), ]

  # all -----------------------------------------
  ci_file_100 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      100,
      ".Rds"
    )
  )
  ci_100 <- readRDS(
    ci_file_100
  )
  ci_100 <- ci_100[which(ci_100$interval <= delta_t_max), ]
  ci_100 <- ci_100[which(ci_100$model == model), ]

  ci_file_200 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      200,
      ".Rds"
    )
  )
  ci_200 <- readRDS(
    ci_file_200
  )
  ci_200 <- ci_200[which(ci_200$interval <= delta_t_max), ]
  ci_200 <- ci_200[which(ci_200$model == model), ]

  ci_file_500 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      500,
      ".Rds"
    )
  )
  ci_500 <- readRDS(
    ci_file_500
  )
  ci_500 <- ci_500[which(ci_500$interval <= delta_t_max), ]
  ci_500 <- ci_500[which(ci_500$model == model), ]

  ci_file_1000 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      1000,
      ".Rds"
    )
  )
  ci_1000 <- readRDS(
    ci_file_1000
  )
  ci_1000 <- ci_1000[which(ci_1000$interval <= delta_t_max), ]
  ci_1000 <- ci_1000[which(ci_1000$model == model), ]
  ci_combined <- rbind(
    ci_100,
	ci_200,
	ci_500,
	ci_1000
  )
  # all -----------------------------------------

  if (method == "delta") {
    method_label <- "Delta Method"
  }
  if (method == "mc") {
    method_label <- "MC Method"
  }
  graphics::plot.default(
    x = 0,
    y = 0,
    xlim = range(ci_combined$interval),
    ylim = range(c(ci_combined$est, ci_combined$ll, ci_combined$ul)),
    type = "n",
    xlab = "Time-Interval",
    ylab = "Estimate",
    main =  paste0(
      gsub(
        pattern = "(^|[[:space:]])([[:alpha:]])",
        replacement = "\\1\\U\\2",
        x = effect,
        perl = TRUE
      ),
      " Effect",
      " | ",
      method_label,
      " | ",
      "n = ",
      n
    )
  )
  ci <- ci[which(ci$effect == effect), ]
  ci <- ci[which(ci$method == method), ]
  if (effect == "total") {
    col <- "#5e3c99"
  }
  if (effect == "direct") {
    col <- "#2c7bb6"
  }
  if (effect == "indirect") {
    col <- "#d7191c"
  }
  for (i in seq_along(ci$interval)) {
    if (!(ci$ll[i] <= 0 && 0 <= ci$ul[i])) {
      graphics::segments(
        x0 = ci$interval[i],
        y0 = ci$ll[i],
        x1 = ci$interval[i],
        y1 = ci$ul[i],
        col = col,
        lty = 3,
        lwd = 1
      )
    }
  }
  graphics::abline(
    h = 0
  )
  graphics::lines(
    x = ci$interval,
    y = ci$est,
    type = "l",
    col = col,
    lty = 1,
    lwd = 3
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ll,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ul,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
}
```


