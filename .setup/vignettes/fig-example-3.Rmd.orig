---
title: "Illustrative Example 3 - Regions of Significance"
author: "Ivan Jacob Agaloos Pesigan"
output: rmarkdown::html_vignette
vignette: >
  %\VignetteIndexEntry{Illustrative Example 3 - Regions of Significance}
  %\VignetteEngine{knitr::rmarkdown}
  %\VignetteEncoding{UTF-8}
---

This vignette accompanies Illustrative Example 3. The goal of the example is to visualize regions of significance, that is, a range of time intervals, where the effects are significantly different from zero, using confidence intervals for the direct, indirect, and total effects from the continuous-time vector autoregressive model drift matrix $\boldsymbol{\Phi}$ for a range of time intervals. This example features `plot` methods for the `DeltaMed` and `MCMed` functions from the `cTMed` package.

```{r}
#| include = FALSE
knitr::opts_chunk$set(
  collapse = TRUE,
  fig.path = "fig-vignettes-example-3-",
  fig.cap = "",
  fig.width = 8.5 / 1.5,
  fig.height = 11 / 2.5,
  fig.retina = 2,
  dpi = 300,
  comment = "#>",
  dev = "ragg_png"
)
```

```{r}
#| include = FALSE
root <- rprojroot::is_rstudio_project
n <- 1000
fit <- readRDS(
  root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "fit-example-ct-",
      n,
      ".Rds"
    )
  )
)
```

```{r}
#| include = FALSE
library(dynr)
library(cTMed)
```

```{r}
#| eval = FALSE
library(dynr)
library(cTMed)
```

## Summary of CT-VAR Estimates

The object `fit` contains the fitted `dynr` model.

```{r}
summary(fit)
```

## Extract Elements of the Drift Matrix

We extract the elements of the drift matrix and the corresponding sampling variance-covariance matrix from the `fit` object.

```{r}
varnames <- c(
  "phi_11",
  "phi_21",
  "phi_31",
  "phi_12",
  "phi_22",
  "phi_32",
  "phi_13",
  "phi_23",
  "phi_33"
)
phi <- matrix(
  data = coef(fit)[varnames],
  nrow = 3
)
colnames(phi) <- rownames(phi) <- c(
  "conflict",
  "knowledge",
  "competence"
)
vcov_phi_vec <- vcov(fit)[varnames, varnames]
```

## Delta Method Confidence Intervals For The Direct, Indirect, and Total Effects

Using the `DeltaMed` function from the `cTMed` package, confidence intervals for the direct, indirect, and total effects for a long sequence of time interval values. This makes regions of significance more visible. Consider using the `ncores` argument to use multiple cores when the `delta_t` vector is long. The `plot` method for the `DeltaMed` presents the regions of significance visually represented by shaded areas in the plot.

```{r}
delta <- DeltaMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = seq(from = 0, to = 10, length.out = 1000)
)
plot(delta)
```

## Monte Carlo Method Confidence Intervals For The Direct, Indirect, and Total Effects

Using the `MCMed` function from the `cTMed` package, confidence intervals for the direct, indirect, and total effects for a long sequence of time interval values. This makes regions of significance more visible. Consider using the `ncores` argument to use multiple cores when the `delta_t` vector is long. The `plot` method for the `MCMed` presents the regions of significance visually represented by shaded areas in the plot.

```{r}
mc <- MCMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = seq(from = 0, to = 10, length.out = 1000),
  seed = 42,
  R = 20000L
)
plot(mc)
```

```{r}
#| include = FALSE
data_process_example_med_plot <- function(n,
                                          model,
                                          effect,
                                          method,
                                          delta_t_max = 10) {
  # find root directory
  root <- rprojroot::is_rstudio_project
  ci_file <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      n,
      ".Rds"
    )
  )
  ci <- readRDS(
    ci_file
  )
  ci <- ci[which(ci$interval <= delta_t_max), ]
  ci <- ci[which(ci$model == model), ]
  ci <- ci[which(ci$n == n), ]

  # all -----------------------------------------
  ci_file_100 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      100,
      ".Rds"
    )
  )
  ci_100 <- readRDS(
    ci_file_100
  )
  ci_100 <- ci_100[which(ci_100$interval <= delta_t_max), ]
  ci_100 <- ci_100[which(ci_100$model == model), ]

  ci_file_200 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      200,
      ".Rds"
    )
  )
  ci_200 <- readRDS(
    ci_file_200
  )
  ci_200 <- ci_200[which(ci_200$interval <= delta_t_max), ]
  ci_200 <- ci_200[which(ci_200$model == model), ]

  ci_file_500 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      500,
      ".Rds"
    )
  )
  ci_500 <- readRDS(
    ci_file_500
  )
  ci_500 <- ci_500[which(ci_500$interval <= delta_t_max), ]
  ci_500 <- ci_500[which(ci_500$model == model), ]

  ci_file_1000 <- root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "ci-example-",
      1000,
      ".Rds"
    )
  )
  ci_1000 <- readRDS(
    ci_file_1000
  )
  ci_1000 <- ci_1000[which(ci_1000$interval <= delta_t_max), ]
  ci_1000 <- ci_1000[which(ci_1000$model == model), ]
  ci_combined <- rbind(
    ci_100,
	ci_200,
	ci_500,
	ci_1000
  )
  # all -----------------------------------------

  if (method == "delta") {
    method_label <- "Delta Method"
  }
  if (method == "mc") {
    method_label <- "MC Method"
  }
  graphics::plot.default(
    x = 0,
    y = 0,
    xlim = range(ci_combined$interval),
    ylim = range(c(ci_combined$est, ci_combined$ll, ci_combined$ul)),
    type = "n",
    xlab = "Time Interval",
    ylab = "Estimate",
    main =  paste0(
      gsub(
        pattern = "(^|[[:space:]])([[:alpha:]])",
        replacement = "\\1\\U\\2",
        x = effect,
        perl = TRUE
      ),
      " Effect",
      " | ",
      method_label,
      " | ",
      "n = ",
      n
    )
  )
  ci <- ci[which(ci$effect == effect), ]
  ci <- ci[which(ci$method == method), ]
  if (effect == "total") {
    col <- "#5e3c99"
  }
  if (effect == "direct") {
    col <- "#2c7bb6"
  }
  if (effect == "indirect") {
    col <- "#d7191c"
  }
  for (i in seq_along(ci$interval)) {
    if (!(ci$ll[i] <= 0 && 0 <= ci$ul[i])) {
      graphics::segments(
        x0 = ci$interval[i],
        y0 = ci$ll[i],
        x1 = ci$interval[i],
        y1 = ci$ul[i],
        col = col,
        lty = 3,
        lwd = 1
      )
    }
  }
  graphics::abline(
    h = 0
  )
  graphics::lines(
    x = ci$interval,
    y = ci$est,
    type = "l",
    col = col,
    lty = 1,
    lwd = 3
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ll,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ul,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
}
```


