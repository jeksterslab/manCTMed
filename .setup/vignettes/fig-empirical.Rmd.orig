```{r}
#| include = FALSE
knitr::opts_chunk$set(
  collapse = TRUE,
  fig.path = "fig-vignettes-empirical-",
  fig.cap = "",
  fig.width = 8.5 / 1.5,
  fig.height = 11 / 2.5,
  fig.retina = 2,
  dpi = 300,
  comment = "#>",
  dev = "ragg_png"
)
```

```{r}
#| include = FALSE
data_process_empirical_med_plot <- function(effect,
                                            method,
                                            delta_t_max = 15) {
  # find root directory
  root <- rprojroot::is_rstudio_project
  ci_file <- root$find_file(
    ".setup",
    "data-raw",
    "ci-empirical.Rds"
  )
  ci <- readRDS(
    ci_file
  )   
  ci <- ci[which(ci$interval <= delta_t_max), ]
  if (method == "delta") {
    method_label <- "Delta Method"
  }
  if (method == "mc") {
    method_label <- "Monte Carlo Method"
  }
  graphics::plot.default(
    x = 0,
    y = 0,
    xlim = range(ci$interval),
    ylim = range(c(ci$est, ci$ll, ci$ul)),
    type = "n",
    xlab = "Time-Interval",
    ylab = "Estimate",
    main =  paste0(
      gsub(
        pattern = "(^|[[:space:]])([[:alpha:]])",
        replacement = "\\1\\U\\2",
        x = effect,
        perl = TRUE
      ),
      " Effect",
      " | ",
      method_label
    )
  )
  ci <- ci[which(ci$effect == effect), ]
  ci <- ci[which(ci$method == method), ]
  if (effect == "total") {
    col <- "#5e3c99"
  }
  if (effect == "direct") {
    col <- "#2c7bb6"
  }
  if (effect == "indirect") {
    col <- "#d7191c"
  }
  for (i in seq_along(ci$interval)) {
    if (!(ci$ll[i] <= 0 && 0 <= ci$ul[i])) {
      graphics::segments(
        x0 = ci$interval[i],
        y0 = ci$ll[i],
        x1 = ci$interval[i],
        y1 = ci$ul[i],
        col = col,
        lty = 3,
        lwd = 1
      )
    }
  }
  graphics::abline(
    h = 0
  )
  # delta
  graphics::lines(
    x = ci$interval,
    y = ci$est,
    type = "l",
    col = col,
    lty = 1,
    lwd = 2
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ll,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
  graphics::lines(
    x = ci$interval,
    y = ci$ul,
    type = "l",
    col = col,
    lty = 3,
    lwd = 2
  )
}
```

```{r, direct-delta}
#| echo = FALSE
data_process_empirical_med_plot(effect = "direct", method = "delta")
```

```{r, direct-mc}
#| echo = FALSE
data_process_empirical_med_plot(effect = "direct", method = "mc")
```

```{r, indirect-delta}
#| echo = FALSE
data_process_empirical_med_plot(effect = "indirect", method = "delta")
```

```{r, indirect-mc}
#| echo = FALSE
data_process_empirical_med_plot(effect = "indirect", method = "mc")
```

```{r, total-delta}
#| echo = FALSE
data_process_empirical_med_plot(effect = "total", method = "delta")
```

```{r, total-mc}
#| echo = FALSE
data_process_empirical_med_plot(effect = "total", method = "mc")
```
