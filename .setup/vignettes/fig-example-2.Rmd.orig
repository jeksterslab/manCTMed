```{r}
#| include = FALSE
root <- rprojroot::is_rstudio_project
n <- 500
fit <- readRDS(
  root$find_file(
    ".setup",
    "data-raw",
    paste0(
      "fit-example-ct-",
      n,
      ".Rds"
    )
  )
)
```

```{r}
#| include = FALSE
library(dynr)
library(cTMed)
```

```{r}
#| eval = FALSE
library(dynr)
library(cTMed)
```

## Summary of CT-VAR Estimates

```{r}
summary(fit)
```

## Extract Elements of the Drift Matrix

```{r}
varnames <- c(
  "phi_11",
  "phi_21",
  "phi_31",
  "phi_12",
  "phi_22",
  "phi_32",
  "phi_13",
  "phi_23",
  "phi_33"
)
phi <- matrix(
  data = coef(fit)[varnames],
  nrow = 3
)
colnames(phi) <- rownames(phi) <- c(
  "conflict",
  "knowledge",
  "competence"
)
vcov_phi_vec <- vcov(fit)[varnames, varnames]
```

## Delta Method Confidence Intervals For The Direct, Indirect, and Total Effects

Here we use time-intervals 1, 2, and 3.

```{r}
DeltaMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = c(1, 2, 3)
)
```

## Monte Carlo Method Confidence Intervals For The Direct, Indirect, and Total Effects

```{r}
MCMed(
  phi = phi,
  vcov_phi_vec = vcov_phi_vec,
  from = "conflict",
  to = "competence",
  med = "knowledge",
  delta_t = c(1, 2, 3),
  seed = 42,
  R = 20000L
)
```
