    -0.13, -0.18, -0.17, -0.08, 0.02, 0.03, -0.03, 0.02, 0.29, 0.3, 0.27, 0.38, 0.15, 0.21, 0.41, 0.34, 0.25, 0.38, 0.63, 1
  ),
  nrow = 20
)
data <- MASS::mvrnorm(
  n = n,
  mu = rep(
    x = 0,
    times = dim(correlations)[1]
  ),
  Sigma = correlations,
  empirical = TRUE
)
conflict <- t(
  data[, 1:4]
)
dim(conflict) <- NULL
knowledge <- t(
  data[, 13:16]
)
dim(knowledge) <- NULL
competence <- t(
  data[, 17:20]
)
dim(competence) <- NULL
id <- sapply(
  X = 1:n,
  FUN = function(i) {
    rep(x = i, times = 4)
  }
)
dim(id) <- NULL
data <- as.data.frame(
  cbind(
    id = id,
    time = 0:3,
    conflict = conflict,
    knowledge = knowledge,
    competence = competence
  )
)
varnames <- c(
  "conflict",
  "knowledge",
  "competence"
)
data <- dynUtils::InsertNA(
  data = data,
  id = "id",
  time = "time",
  observed = varnames,
  delta_t = 0.10,
  ncores = parallel::detectCores()
)
summary(data)
head(data)
```
