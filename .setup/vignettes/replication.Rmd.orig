```{r}
library(manCTMed)
```

## Data Generation

```{r}
set.seed(1)
sim <- GenData(taskid = 1)
plot(sim)
data <- RandomMeasurement(sim)
str(data)
```

## Model Fitting

```{r}
fit <- FitDynr(data = data, taskid = 1)
summary(fit)
phi_hat <- PhiHat(fit)
theta_hat <- ThetaHat(fit)
```

## Confidence Intervals (Unstandardized)

### Model $\eta_X \to \eta_M \to \eta_Y$

#### Delta Method

```{r}
delta <- DeltaXMY(phi_hat)
plot(delta)
```

#### Monte Carlo Method

```{r}
mc <- MCXMY(phi_hat, seed = 42)
plot(mc)
```

### Model $\eta_Y \to \eta_M \to \eta_M$

#### Delta Method

```{r}
delta <- DeltaYMX(phi_hat)
plot(delta)
```

#### Monte Carlo Method

```{r}
mc <- MCYMX(phi_hat, seed = 42)
plot(mc)
```

## Confidence Intervals (Standardized)

### Model $\eta_X \to \eta_M \to \eta_Y$

#### Delta Method

```{r}
delta <- DeltaStdXMY(theta_hat)
plot(delta)
```

#### Monte Carlo Method

```{r}
mc <- MCStdXMY(theta_hat, seed = 1)
plot(mc)
```

### Model $\eta_Y \to \eta_M \to \eta_M$

#### Delta Method

```{r}
delta <- DeltaStdYMX(theta_hat)
plot(delta)
```

#### Monte Carlo Method

```{r}
mc <- MCStdYMX(theta_hat, seed = 1)
plot(mc)
```
